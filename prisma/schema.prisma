generator client {
  provider = "prisma-client"
  output   = "./app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model downloads {
  id            Int       @id @default(autoincrement())
  file_id       String?
  downloaded_at DateTime? @default(now()) @db.Timestamp(6)
  ip            String?
  user_agent    String?
  files         files?    @relation(fields: [file_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model files {
  id             String      @id
  filename       String
  content_type   String
  size           BigInt
  uploaded_at    DateTime?   @default(now()) @db.Timestamp(6)
  expires_at     DateTime?   @db.Timestamp(6)
  storage        String?     @default("hot")
  max_downloads  Int?
  download_count Int?        @default(0)
  password_hash  String?
  email_sender   String?
  email_recipient String?
  upload_token   String?     @unique
  download_token String?     @unique
  downloads      downloads[]
}

model multipart_uploads {
  file_id    String    @id
  upload_id  String
  filename   String
  chunk_size Int
  total_size BigInt
  parts      Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model upload_tokens {
  token      String    @id
  created_at DateTime? @default(now()) @db.Timestamp(6)
  expires_at DateTime  @db.Timestamp(6)
  used       Boolean?  @default(false)
}
